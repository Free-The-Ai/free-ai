---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config/site";
import PaidModelTable from "../components/PaidModelTable";
import {
    buildBreadcrumbJsonLd,
    buildMachineReadableResourcesJsonLd,
    buildOrganizationJsonLd,
    buildPaidPlanJsonLd,
    buildSoftwareJsonLd,
    buildWebsiteJsonLd,
    buildWebApiJsonLd,
} from "../utils/jsonLd";
import paidPlan from "../data/paid-plan.json";

const jsonLd = [
    buildWebsiteJsonLd(),
    buildOrganizationJsonLd(),
    buildSoftwareJsonLd(),
    buildWebApiJsonLd(),
    buildMachineReadableResourcesJsonLd({
        paidModelCount: paidPlan.model_groups.reduce((total, group) => total + group.models.length, 0),
        paidUpdatedAt: paidPlan.updated_at,
    }),
    buildPaidPlanJsonLd(paidPlan.plan),
    buildBreadcrumbJsonLd([
        { name: "FreeTheAi", url: "https://freetheai.xyz/home" },
        { name: "Pricing", url: "https://freetheai.xyz/pricing" },
    ]),
];

const paidModelCount = paidPlan.model_groups.reduce(
    (total, group) => total + group.models.length,
    0,
);
const heroLimits = paidPlan.plan.limits.filter(({ label }) =>
    ["request units / day", "request units / hour", "concurrent requests"].includes(label),
);
---

<Layout
    title="FreeTheAi Paid API Pricing - $8 Higher-Power Model Slots"
    description="FreeTheAi paid API pricing: $8/month launch slots, 24 paid aliases, request-unit costs, hourly and daily limits, and a separate higher-power model catalog."
    jsonLd={jsonLd}
    currentPath="/pricing"
>
    <main class="pricing-main">
        <section class="pricing-hero shell">
            <div class="pricing-hero-copy">
                <span class="eyebrow">Paid API</span>
                <h1>More powerful models when the free API is not enough.</h1>
                <p class="hero-text">
                    The free API stays free. The paid plan is a separate, limited-seat
                    option for builders who need stronger models, steadier access, and
                    higher-powered routes without crowding the free pools.
                </p>
                <div class="hero-actions">
                    <a class="primary-button" href={siteConfig.socials.discord} target="_blank" rel="noreferrer">
                        Claim a paid slot
                        <span>&rarr;</span>
                    </a>
                    <a class="ghost-button" href="/models">Browse free models</a>
                </div>
                <p class="pricing-note">
                    Launch slots are limited while we measure real usage and keep the
                    paid account pools healthy.
                </p>
                <p class="pricing-endpoint docs-code-group">
                    Paid base URL: <code>{paidPlan.base_url}</code>
                    <button class="copy-btn pricing-copy-button" type="button" title="Copy paid base URL">
                        <span class="material-symbols-outlined">content_copy</span>
                    </button>
                </p>
            </div>

            <article class="pricing-card pricing-plan-card">
                <div class="pricing-plan-head">
                    <div>
                        <span class="eyebrow">Launch plan</span>
                        <h2>{paidPlan.plan.name}</h2>
                    </div>
                    <span>{paidModelCount} aliases</span>
                </div>
                <div class="pricing-price">
                    <strong>{paidPlan.plan.price}</strong>
                    <span>/ {paidPlan.plan.period}</span>
                </div>
                <div class="pricing-plan-strip">
                    {heroLimits.map(({ value, label }) => (
                        <div>
                            <strong>{value}</strong>
                            <span>{label}</span>
                        </div>
                    ))}
                </div>
                <p class="pricing-plan-foot">Includes monthly quota and premium-pool guardrails.</p>
            </article>
        </section>

        <section class="section shell pricing-section">
            <div class="section-head">
                <span class="eyebrow">How limits work</span>
                <h2>Affordable, but protected from pool drain.</h2>
                <p>
                    The paid plan is designed to hook real builders without letting one
                    user burn through the launch inventory. Each request deducts the
                    listed model cost from your hourly, daily, and monthly budget.
                </p>
            </div>

            <div class="pricing-feature-grid">
                <article class="capability-card">
                    <span class="capability-icon material-symbols-outlined">bolt</span>
                    <h3>Different catalog from free</h3>
                    <p>
                        Paid models live on separate <code>sky/*</code> and
                        <code>pbl/*</code> aliases. They are meant for harder coding,
                        reasoning, and long-form work.
                    </p>
                </article>
                <article class="capability-card">
                    <span class="capability-icon material-symbols-outlined">speed</span>
                    <h3>Request-unit pricing</h3>
                    <p>
                        Cheap hook models can cost <code>0.5</code> units, normal
                        models cost <code>1</code>, and heavy models cost up to
                        <code>4</code> units per request.
                    </p>
                </article>
                <article class="capability-card">
                    <span class="capability-icon material-symbols-outlined">lock</span>
                    <h3>Launch safety limits</h3>
                    <p>
                        Accounts have hourly, daily, monthly, and concurrency limits.
                        The <code>pbl/*</code> pool also has a separate
                        <code>250</code> unit daily cap to keep premium routes
                        available.
                    </p>
                </article>
            </div>
        </section>

        <section class="section shell pricing-section">
            <div class="section-head">
                <span class="eyebrow">Model costs</span>
                <h2>Search paid aliases.</h2>
            </div>

            <PaidModelTable groups={paidPlan.model_groups} client:load />
        </section>

        <section class="section shell pricing-section">
            <article class="cta-banner pricing-cta">
                <div>
                    <span class="eyebrow">Limited launch</span>
                    <h2>Want a slot?</h2>
                    <p>
                        Join Discord and ask for the paid plan. The owner will issue a
                        monthly paid API key while launch slots are available.
                    </p>
                </div>
                <div class="cta-actions">
                    <a class="primary-button" href={siteConfig.socials.discord} target="_blank" rel="noreferrer">
                        Join Discord
                        <span>&rarr;</span>
                    </a>
                    <a class="ghost-button" href="/docs">Read API docs</a>
                </div>
            </article>
        </section>
    </main>
</Layout>

<style>
    .pricing-main {
        gap: 32px;
        padding: 22px 0 72px;
    }

    .pricing-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(300px, 420px);
        gap: clamp(24px, 4vw, 44px);
        align-items: center;
        min-height: auto;
        padding: clamp(26px, 4.4vw, 48px);
    }

    .pricing-hero-copy {
        display: grid;
        gap: 16px;
        min-width: 0;
    }

    .pricing-hero h1 {
        max-width: 13.5ch;
        font-size: clamp(2.45rem, 5.8vw, 4.85rem);
        line-height: 0.98;
        letter-spacing: -0.055em;
    }

    .pricing-note {
        max-width: 58ch;
        margin: 0;
        color: var(--dim);
        font-size: 0.9rem;
        line-height: 1.55;
    }

    .pricing-endpoint {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        width: fit-content;
        max-width: 100%;
        margin: 2px 0 0;
        padding: 10px 12px;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-sm);
        background: var(--sk-inset-bg);
        box-shadow: var(--sk-inset-shadow);
        color: var(--muted);
        font-size: 0.85rem;
    }

    .pricing-endpoint code {
        color: var(--text);
        font-family: var(--font-mono);
    }

    .pricing-card {
        min-width: 0;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius);
        background: var(--sk-shell-bg);
        box-shadow: var(--sk-raised-shadow);
        padding: clamp(20px, 2.7vw, 28px);
    }

    .pricing-card p {
        margin: 0;
        color: var(--muted);
        line-height: 1.65;
    }

    .pricing-plan-card {
        position: relative;
        overflow: hidden;
        display: grid;
        justify-self: end;
        width: min(100%, 420px);
        gap: 18px;
        padding: clamp(20px, 2.4vw, 26px);
    }

    .pricing-plan-card::before {
        content: "";
        position: absolute;
        inset: -40% -20% auto auto;
        width: 260px;
        height: 260px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(238, 93, 32, 0.22), transparent 64%);
        pointer-events: none;
    }

    .pricing-plan-head {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding-bottom: 14px;
        border-bottom: 1px solid var(--sk-border);
    }

    .pricing-plan-head h2 {
        margin: 6px 0 0;
        color: var(--text);
        font-size: clamp(1.25rem, 2.4vw, 1.65rem);
        letter-spacing: -0.035em;
    }

    .pricing-plan-head > span {
        display: inline-flex;
        align-items: center;
        min-height: 30px;
        padding: 0 10px;
        border: 1px solid rgba(238, 93, 32, 0.28);
        border-radius: 999px;
        background: rgba(238, 93, 32, 0.08);
        color: var(--accent-text);
        font-family: var(--font-mono);
        font-size: 0.68rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-shadow: var(--accent-text-glow);
        white-space: nowrap;
    }

    .pricing-price {
        display: flex;
        align-items: flex-end;
        gap: 12px;
    }

    .pricing-price strong {
        color: var(--accent-text-strong);
        font-family: var(--font-serif);
        font-size: clamp(3.3rem, 6.8vw, 4.8rem);
        font-weight: 500;
        line-height: 0.88;
        letter-spacing: -0.08em;
        text-shadow: var(--accent-text-glow);
    }

    .pricing-price span {
        margin-bottom: 8px;
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .pricing-plan-strip,
    .pricing-feature-grid {
        display: grid;
        gap: 12px;
    }

    .pricing-plan-strip {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .pricing-plan-strip div {
        display: grid;
        gap: 3px;
        min-width: 0;
        padding: 10px;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-sm);
        background: var(--sk-inset-bg);
        box-shadow: var(--sk-inset-shadow);
    }

    .pricing-plan-strip strong {
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 0.95rem;
    }

    .pricing-plan-strip span {
        color: var(--muted);
        font-size: 0.7rem;
        line-height: 1.35;
    }

    .pricing-plan-foot {
        color: var(--dim);
        font-size: 0.82rem;
        line-height: 1.45;
    }

    .pricing-feature-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .pricing-section {
        gap: clamp(22px, 3vw, 30px);
        padding: clamp(24px, 4vw, 38px);
    }

    .paid-table-panel {
        display: grid;
        gap: 16px;
    }

    .paid-table-toolbar,
    .paid-table-filters {
        display: grid;
        gap: 12px;
    }

    .paid-table-search {
        max-width: 560px;
    }

    .paid-model-table {
        display: grid;
        gap: 6px;
        overflow-x: auto;
        padding-bottom: 2px;
    }

    .paid-model-row {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) 92px 92px 112px 42px;
        gap: 12px;
        align-items: center;
        min-width: 760px;
        padding: 10px 12px;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-sm);
        background: var(--sk-inset-bg);
        box-shadow: var(--sk-inset-shadow);
    }

    .paid-model-row-head {
        padding: 2px 12px 6px;
        border: 0;
        background: transparent;
        box-shadow: none;
        color: var(--dim);
        font-family: var(--font-mono);
        font-size: 0.68rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .paid-model-name {
        min-width: 0;
    }

    .paid-model-row code {
        min-width: 0;
        overflow: hidden;
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 0.78rem;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .pricing-route-pill {
        width: fit-content;
        max-width: 100%;
        padding: 4px 7px;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-sm);
        background: rgba(255, 255, 255, 0.035);
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
    }

    .paid-model-row strong {
        color: var(--accent-text);
        font-family: var(--font-mono);
        font-size: 0.74rem;
        font-weight: 700;
        text-shadow: var(--accent-text-glow);
        white-space: nowrap;
    }

    .paid-model-empty {
        padding: 18px;
        border: 1px dashed var(--sk-border);
        border-radius: var(--radius-sm);
        color: var(--muted);
        font-size: 0.9rem;
    }

    .pricing-copy-button,
    .pricing-model-copy {
        flex: 0 0 auto;
        width: 30px;
        height: 30px;
        min-height: 30px;
        padding: 0;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-sm);
        background: var(--sk-inset-bg);
        color: var(--muted);
        box-shadow: var(--sk-inset-shadow);
        cursor: pointer;
    }

    .pricing-copy-button:hover,
    .pricing-model-copy:hover {
        color: var(--text);
        border-color: rgba(238, 93, 32, 0.42);
    }

    .pricing-cta {
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
    }

    @media (max-width: 1120px) {
        .pricing-hero,
        .pricing-cta {
            grid-template-columns: 1fr;
        }

        .pricing-plan-card {
            justify-self: stretch;
            width: 100%;
        }

        .pricing-hero h1 {
            max-width: 15ch;
        }

        .pricing-feature-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 560px) {
        .pricing-main {
            gap: 24px;
            padding-top: 10px;
        }

        .pricing-hero {
            gap: 22px;
            padding: 18px;
        }

        .pricing-hero h1 {
            font-size: clamp(2.25rem, 13vw, 3.2rem);
            line-height: 1.02;
        }

        .pricing-card {
            padding: 16px;
        }

        .pricing-section {
            padding: 18px;
        }

        .pricing-plan-strip {
            grid-template-columns: 1fr;
        }

        .pricing-plan-head {
            flex-direction: column;
            gap: 8px;
        }
    }
</style>
