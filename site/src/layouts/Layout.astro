---
import BaseHead from '../components/BaseHead.astro';
import Logo from '../components/Logo.astro';
import NavDrawer from '../components/NavDrawer';
import SmoothScroll from '../components/SmoothScroll';
import HapticsInit from '../components/HapticsInit';
import SoundProvider from '../components/SoundProvider';
import { ToastRegion } from '../components/ui';
import { siteConfig } from '../config/site';
import {
	SETUP_GUIDES,
	CATEGORY_ORDER,
	CATEGORY_LABELS,
	setupGuidesByCategory,
} from '../data/setup-guides';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	jsonLd?: Record<string, unknown>[];
	currentPath?: string;
	keywords?: string;
}

const {
	title = siteConfig.title,
	description = siteConfig.description,
	image = siteConfig.defaults.ogImage,
	jsonLd = [],
	currentPath = '',
	keywords,
} = Astro.props;

const navLinks: [string, string][] = [
	['/home', 'Home'],
	['/docs', 'Docs'],
	['/models', 'Models'],
	['/pricing', 'Pricing'],
	['/status', 'Status'],
];

const setupCategories = setupGuidesByCategory();
const setupGuideCount = SETUP_GUIDES.length;
const isSetupActive = currentPath === '/setup' || currentPath.startsWith('/setup/');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} jsonLd={jsonLd} keywords={keywords} />
	</head>
	<body>
		<SoundProvider client:load config={{ volume: 0.3, theme: "aero" }}>
		<div id="loader" style="position:fixed;inset:0;z-index:9999;background:#0f0f0f;display:flex;align-items:center;justify-content:center">
			<style>
				@keyframes pulse{0%,100%{opacity:.4}50%{opacity:1}}
				@keyframes draw{0%{stroke-dashoffset:200}100%{stroke-dashoffset:0}}
				.load-ring{animation:pulse 2s ease-in-out infinite}
				.load-line{stroke-dasharray:200;stroke-dashoffset:200;animation:draw 2.5s ease-out infinite}
			</style>
			<div style="display:flex;flex-direction:column;align-items:center;gap:24px">
				<svg width="40" height="40" viewBox="0 0 40 40" style="animation:pulse 2s ease-in-out infinite">
					<circle class="load-ring" cx="20" cy="20" r="16" fill="none" stroke="#ee5d20" stroke-width="1.5" opacity=".5"/>
					<line class="load-line" x1="20" y1="10" x2="20" y2="30" stroke="#ee5d20" stroke-width="1.5"/>
					<line class="load-line" x1="12" y1="14" x2="28" y2="14" stroke="#ee5d20" stroke-width="1" stroke-dashoffset="100" style="animation-delay:.3s"/>
				</svg>
				<Logo width={200} style="opacity:.3" />
			</div>
		</div>
		<script>
			(function(){
				var l=document.getElementById('loader');
				function hide(){l.style.opacity='0';l.style.transition='opacity .5s ease';setTimeout(function(){l.remove()},600)}
				if(document.readyState==='interactive'||document.readyState==='complete'){setTimeout(hide,600)}
				else{document.addEventListener('DOMContentLoaded',function(){setTimeout(hide,600)})}
			})();
		</script>
		<div class="page-shell">
			<header class="site-header">
				<nav class="nav">
					<a class="brand" href="/home"><Logo width={160} /></a>
					<div class="nav-links">
						{navLinks.map(([href, label]) => (
							<a
								href={href}
								class={currentPath === href ? 'is-active' : ''}
							>
								{label}
							</a>
						))}
						<div class={`nav-dropdown${isSetupActive ? ' is-active' : ''}`}>
							<button
								type="button"
								class={`nav-dropdown-trigger${isSetupActive ? ' is-active' : ''}`}
								aria-haspopup="true"
								aria-expanded="false"
							>
								Setup
								<span class="nav-dropdown-caret" aria-hidden="true"></span>
							</button>
							<div class="nav-dropdown-panel" role="menu" aria-label="Setup guides">
								<div class="nav-dropdown-head">
									<a href="/setup" class="nav-dropdown-head-link">
										<strong>Setup guides</strong>
										<span>{setupGuideCount} apps and clients</span>
									</a>
								</div>
								{CATEGORY_ORDER.flatMap((category) => {
									const guides = setupCategories[category];
									if (!guides || guides.length === 0) return [];
									return [
										<div class="nav-dropdown-group" key={category}>
											<span class="nav-dropdown-group-label">
												{CATEGORY_LABELS[category]}
											</span>
											{guides.map((guide) => (
												<a
													href={`/setup/${guide.slug}`}
													class="nav-dropdown-item"
													role="menuitem"
												>
													{guide.logoUrl && <img src={guide.logoUrl} alt="" class="nav-dropdown-icon" width="16" height="16" loading="lazy" />}
													<strong>{guide.name}</strong>
													<span>{guide.tagline}</span>
												</a>
											))}
										</div>,
									];
								})}
							</div>
						</div>
						<a href={siteConfig.socials.github} target="_blank" rel="noreferrer">GitHub</a>
					</div>
					<div class="nav-actions">
						<a class="discord-button" href={siteConfig.socials.discord} target="_blank" rel="noreferrer">
							Join Discord
						</a>
						<a
							class="discord-button donate-button"
							href={siteConfig.socials.donate}
							target="_blank"
							rel="noreferrer"
							aria-label="Support FreeTheAi on Buy Me a Coffee"
						>
							<span class="donate-button-icon" aria-hidden="true">&#9829;</span>
							<span class="donate-button-label">Donate</span>
						</a>
					</div>
					<NavDrawer currentPath={currentPath} client:load />
				</nav>
			</header>

			<div class="site-main">
				<slot />
			</div>

			<footer class="site-footer">
				<div class="footer-links">
					<a href="/quickstart">Quickstart</a>
					<a href="/setup">Setup guides</a>
					<a href="/models">Models</a>
					<a href="/pricing">Pricing</a>
					<a href="/status">Status</a>
					<a href="/docs">Docs</a>
					<a href="/team">Team</a>
					<a href="/what-is-free-the-ai">What is FreeTheAi</a>
					<a href={siteConfig.socials.github} target="_blank" rel="noreferrer">GitHub</a>
					<a href={siteConfig.socials.discord} target="_blank" rel="noreferrer">Discord</a>
					<a class="footer-donate-link" href={siteConfig.socials.donate} target="_blank" rel="noreferrer">
						<span aria-hidden="true">💗</span>
						Donate
					</a>
				</div>
				<div class="footer-bottom">free tier stays free. paid slots are optional.</div>
			</footer>

		<ToastRegion client:load />
		<SmoothScroll client:load />
		<HapticsInit client:load />
	</div>

	<script>
		// Auto-decorate interactive elements with haptic hints
		(function(){
			const MAP = {
				'a[href]': 'tap',
				'button:not([data-haptic])': 'tap',
				'.primary-button': 'heavy',
				'.discord-button': 'heavy',
				'.nav-hamburger': 'press',
				'.copy-btn': 'select',
				'.model-card': 'tap',
				'.status-card': 'tap',
				'.catalog-chip': 'press',
				'.kb-accordion__trigger': 'press',
				'.docs-section-head': 'press',
				'select:not([data-haptic])': 'select',
				'input[type="checkbox"]:not([data-haptic])': 'select',
			};
			function decorate(root) {
				for (const [sel, pattern] of Object.entries(MAP)) {
					root.querySelectorAll(sel).forEach(el => {
						if (!el.hasAttribute('data-haptic')) el.setAttribute('data-haptic', pattern);
					});
				}
			}
			decorate(document);
			if (typeof MutationObserver !== 'undefined') {
				new MutationObserver(muts => {
					for (const m of muts) m.addedNodes.forEach(n => {
						if (n.nodeType === 1 && typeof n.querySelectorAll === 'function') decorate(n);
					});
				}).observe(document.body, { childList: true, subtree: true });
			}
		})();
	</script>
	<script>
		function closestFromEvent(e, selector) {
			if (e.target instanceof Element) return e.target.closest(selector);

			const path = typeof e.composedPath === 'function' ? e.composedPath() : [];
			return path.find(node => node instanceof Element && node.matches(selector)) ?? null;
		}

		document.addEventListener("click", async (e) => {
			const btn = closestFromEvent(e, ".copy-btn");
			if (!btn) return;
			const group = btn.closest?.('.docs-code-group') ?? btn.parentElement;
			const code = group?.querySelector("code");
			if (!code) return;
			try {
				await navigator.clipboard.writeText(code.textContent ?? "");
			} catch (error) {
				console.error("Failed to copy code sample", error);
				return;
			}
			const icon = btn.querySelector(".material-symbols-outlined");
			if (icon) {
				icon.textContent = "check";
				setTimeout(() => {
					icon.textContent = "content_copy";
				}, 2000);
			}
		});
	</script>
	<script>
		(function () {
			var drop = document.querySelector('.nav-dropdown');
			var trigger = document.querySelector('.nav-dropdown-trigger');
			if (!drop || !trigger) return;

			function isOpen() { return drop.classList.contains('is-open'); }

			function open() {
				drop.classList.add('is-open');
				trigger.setAttribute('aria-expanded', 'true');
			}

			function close() {
				drop.classList.remove('is-open');
				trigger.setAttribute('aria-expanded', 'false');
			}

			trigger.addEventListener('click', function (e) {
				e.preventDefault();
				isOpen() ? close() : open();
			});

			document.addEventListener('click', function (e) {
				if (isOpen() && !drop.contains(e.target)) close();
			});

			document.addEventListener('keydown', function (e) {
				if (e.key === 'Escape' && isOpen()) {
					close();
					trigger.focus();
				}
			});

			var panel = drop.querySelector('.nav-dropdown-panel');
			if (panel) {
				panel.addEventListener('focusout', function (e) {
					if (!panel.contains(e.relatedTarget) && !trigger.contains(e.relatedTarget)) close();
				});
			}
		})();
	</script>
	</SoundProvider>
</body>
</html>
