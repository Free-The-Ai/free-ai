---
import Layout from "../layouts/Layout.astro";
import PaidModelTable from "../components/PaidModelTable";
import {
    buildBreadcrumbJsonLd,
    buildMachineReadableResourcesJsonLd,
    buildOrganizationJsonLd,
    buildPaidPlanJsonLd,
    buildSoftwareJsonLd,
    buildWebsiteJsonLd,
    buildWebApiJsonLd,
} from "../utils/jsonLd";
import paidPlan from "../data/paid-plan.json";

const jsonLd = [
    buildWebsiteJsonLd(),
    buildOrganizationJsonLd(),
    buildSoftwareJsonLd(),
    buildWebApiJsonLd(),
    buildMachineReadableResourcesJsonLd({
        paidModelCount: paidPlan.model_groups.reduce((total, group) => total + group.models.length, 0),
        paidUpdatedAt: paidPlan.updated_at,
    }),
    buildPaidPlanJsonLd(paidPlan.plan),
    buildBreadcrumbJsonLd([
        { name: "FreeTheAi", url: "https://freetheai.xyz/home" },
        { name: "Pricing", url: "https://freetheai.xyz/pricing" },
    ]),
];

const paidModelCount = paidPlan.model_groups.reduce(
    (total, group) => total + group.models.length,
    0,
);
const planStats = [
    { value: paidModelCount, label: "paid aliases" },
    { value: "1,000", label: "units / day" },
    { value: "100", label: "units / hour" },
    { value: "3", label: "concurrent" },
];
---

<Layout
    title="FreeTheAi Paid API Pricing - $8 Higher-Power Model Slots"
    description="FreeTheAi paid API pricing: $8/month launch slots, 24 paid aliases, request-unit costs, hourly and daily limits, and a separate higher-power model catalog."
    jsonLd={jsonLd}
    currentPath="/pricing"
>
    <main class="pricing-main">
        <section class="pricing-hero shell">
            <div class="pricing-hero-copy">
                <span class="eyebrow">FreeTheAi ~ Paid plan</span>
                <h1>Premium models at an affordable price.</h1>
                <p class="hero-text">
                    Stable uptime and a different model collection for users who need
                    more than the free pool.
                </p>
                <p class="pricing-note">
                    * Free plan stays free. Paid is only for higher uptime and separate
                    premium routes.
                </p>
            </div>

            <article class="pricing-card pricing-plan-card">
                <div class="pricing-price">
                    <strong>{paidPlan.plan.price}</strong>
                    <span>/ {paidPlan.plan.period}</span>
                </div>
                <div class="pricing-plan-strip">
                    {planStats.map(({ value, label }) => (
                        <div>
                            <strong>{value}</strong>
                            <span>{label}</span>
                        </div>
                    ))}
                </div>
            </article>
        </section>

        <section class="section shell pricing-section">
            <div class="section-head">
                <span class="eyebrow">Model costs</span>
                <h2>Paid aliases.</h2>
            </div>

            <PaidModelTable groups={paidPlan.model_groups} client:load />
        </section>
    </main>
</Layout>

<style is:global>
    .pricing-main {
        gap: 28px;
        padding: 22px 0 64px;
    }

    .pricing-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(280px, 380px);
        gap: clamp(24px, 5vw, 72px);
        align-items: center;
        min-height: auto;
        padding: clamp(28px, 4.6vw, 52px);
    }

    .pricing-hero-copy {
        display: grid;
        gap: 18px;
        min-width: 0;
    }

    .pricing-hero h1 {
        max-width: 15ch;
        font-size: clamp(2.35rem, 4.7vw, 4rem);
        line-height: 1.02;
        letter-spacing: -0.055em;
    }

    .pricing-hero .hero-text {
        max-width: 47ch;
        margin: 0;
    }

    .pricing-note {
        max-width: 56ch;
        margin: 0;
        color: var(--dim);
        font-size: 0.96rem;
        line-height: 1.55;
    }

    .pricing-card {
        min-width: 0;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius);
        background: var(--sk-shell-bg);
        box-shadow: var(--sk-raised-shadow);
        padding: clamp(20px, 2.7vw, 28px);
    }

    .pricing-card p {
        margin: 0;
        color: var(--muted);
        line-height: 1.65;
    }

    .pricing-plan-card {
        position: relative;
        overflow: hidden;
        display: grid;
        justify-self: end;
        width: min(100%, 380px);
        min-height: 240px;
        align-content: space-between;
        gap: 18px;
        padding: clamp(22px, 2.8vw, 32px);
    }

    .pricing-plan-card::before {
        content: "";
        position: absolute;
        inset: -40% -20% auto auto;
        width: 260px;
        height: 260px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(238, 93, 32, 0.22), transparent 64%);
        pointer-events: none;
    }

    .pricing-price {
        display: flex;
        align-items: flex-end;
        gap: 12px;
    }

    .pricing-price strong {
        color: var(--accent-text-strong);
        font-family: var(--font-serif);
        font-size: clamp(3rem, 6vw, 4.2rem);
        font-weight: 500;
        line-height: 0.88;
        letter-spacing: -0.08em;
        text-shadow: var(--accent-text-glow);
    }

    .pricing-price span {
        margin-bottom: 8px;
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .pricing-plan-strip {
        display: grid;
        gap: 12px;
    }

    .pricing-plan-strip {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .pricing-plan-strip div {
        display: grid;
        gap: 3px;
        min-width: 0;
        padding: 10px;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-sm);
        background: var(--sk-inset-bg);
        box-shadow: var(--sk-inset-shadow);
    }

    .pricing-plan-strip strong {
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 0.95rem;
    }

    .pricing-plan-strip span {
        color: var(--muted);
        font-size: 0.7rem;
        line-height: 1.35;
    }

    .pricing-section {
        gap: clamp(22px, 3vw, 30px);
        padding: clamp(24px, 4vw, 38px);
    }

    .paid-table-panel {
        display: grid;
        gap: 16px;
    }

    .paid-table-toolbar,
    .paid-table-filters {
        display: grid;
        gap: 12px;
    }

    .paid-table-search {
        max-width: 560px;
    }

    .paid-model-table {
        display: grid;
        gap: 6px;
        overflow-x: auto;
        padding-bottom: 2px;
    }

    .paid-model-row {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) 92px 92px 112px 42px;
        gap: 12px;
        align-items: center;
        min-width: 760px;
        padding: 10px 12px;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-sm);
        background: var(--sk-inset-bg);
        box-shadow: var(--sk-inset-shadow);
    }

    .paid-model-row-head {
        padding: 2px 12px 6px;
        border: 0;
        background: transparent;
        box-shadow: none;
        color: var(--dim);
        font-family: var(--font-mono);
        font-size: 0.68rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .paid-model-name {
        min-width: 0;
    }

    .paid-model-row code {
        min-width: 0;
        overflow: hidden;
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 0.78rem;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .pricing-route-pill {
        width: fit-content;
        max-width: 100%;
        padding: 4px 7px;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-sm);
        background: rgba(255, 255, 255, 0.035);
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
    }

    .paid-model-row strong {
        color: var(--accent-text);
        font-family: var(--font-mono);
        font-size: 0.74rem;
        font-weight: 700;
        text-shadow: var(--accent-text-glow);
        white-space: nowrap;
    }

    .paid-model-empty {
        padding: 18px;
        border: 1px dashed var(--sk-border);
        border-radius: var(--radius-sm);
        color: var(--muted);
        font-size: 0.9rem;
    }

    .pricing-model-copy {
        flex: 0 0 auto;
        width: 30px;
        height: 30px;
        min-height: 30px;
        padding: 0;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-sm);
        background: var(--sk-inset-bg);
        color: var(--muted);
        box-shadow: var(--sk-inset-shadow);
        cursor: pointer;
    }

    .pricing-model-copy:hover {
        color: var(--text);
        border-color: rgba(238, 93, 32, 0.42);
    }

    @media (max-width: 1120px) {
        .pricing-hero {
            grid-template-columns: 1fr;
        }

        .pricing-plan-card {
            justify-self: stretch;
            width: 100%;
        }

        .pricing-hero h1 {
            max-width: 15ch;
        }

    }

    @media (max-width: 560px) {
        .pricing-main {
            gap: 24px;
            padding-top: 10px;
        }

        .pricing-hero {
            gap: 22px;
            padding: 18px;
        }

        .pricing-hero h1 {
            font-size: clamp(2.15rem, 12vw, 3.05rem);
            line-height: 1.02;
        }

        .pricing-card {
            padding: 16px;
        }

        .pricing-section {
            padding: 18px;
        }

        .pricing-plan-strip {
            grid-template-columns: 1fr;
        }
    }
</style>
