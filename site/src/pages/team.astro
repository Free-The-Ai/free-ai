---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config/site";
import {
    buildWebsiteJsonLd,
    buildOrganizationJsonLd,
    buildSoftwareJsonLd,
    buildWebApiJsonLd,
    buildBreadcrumbJsonLd,
} from "../utils/jsonLd";

interface Member {
    name: string;
    role: string;
    bio: string;
    github: string;
    githubHandle: string;
    avatar: string;
}

const team: Member[] = [
    {
        name: "Vibhek Soni",
        role: "Founder",
        bio: "Wrote the full FreeTheAi API and most of the platform. Started the project to share the AI resources he had access to with everyone.",
        github: "https://github.com/vibheksoni",
        githubHandle: "vibheksoni",
        avatar: "https://avatars.githubusercontent.com/u/102437829?v=4",
    },
    {
        name: "Dr. Vova",
        role: "Team",
        bio: "Helps with frontend and the upcoming GoonPia roleplay site.",
        github: "https://github.com/drvova",
        githubHandle: "drvova",
        avatar: "https://avatars.githubusercontent.com/u/166897058?v=4",
    },
    {
        name: "Dysekt",
        role: "Team",
        bio: "Helps run the Discord side and community ops.",
        github: "https://github.com/DysektAI",
        githubHandle: "DysektAI",
        avatar: "https://avatars.githubusercontent.com/u/33468668?v=4",
    },
    {
        name: "Sai Revanth",
        role: "Discord Manager",
        bio: "Keeps the Discord moving day to day, helps users land their first key, and runs community-side moderation.",
        github: "https://github.com/svsairevanth",
        githubHandle: "svsairevanth",
        avatar: "https://avatars.githubusercontent.com/u/157276603?v=4",
    },
];

const pageDescription =
    "Meet the FreeTheAi team: Vibhek Soni built the full API and platform, Dr. Vova helps with frontend and GoonPia, and Dysekt runs the Discord. Built to share free AI with everyone.";

const teamJsonLd = {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://freetheai.xyz/team#organization",
    name: siteConfig.title,
    url: "https://freetheai.xyz/",
    logo: "https://freetheai.xyz/FreeTheAi.png",
    sameAs: [
        siteConfig.socials.github,
        "https://github.com/Free-The-Ai",
        siteConfig.socials.discord,
    ],
    member: team.map((member) => ({
        "@type": "Person",
        name: member.name,
        jobTitle: member.role,
        url: member.github,
        image: member.avatar,
        description: member.bio,
        sameAs: [member.github],
    })),
};

const jsonLd = [
    buildWebsiteJsonLd(),
    buildOrganizationJsonLd(),
    buildSoftwareJsonLd(),
    buildWebApiJsonLd(),
    teamJsonLd,
    buildBreadcrumbJsonLd([
        { name: "FreeTheAi", url: "https://freetheai.xyz/home" },
        { name: "Team", url: "https://freetheai.xyz/team" },
    ]),
];
---

<Layout
    title="FreeTheAi Team - The People Behind the Free AI API"
    description={pageDescription}
    jsonLd={jsonLd}
    currentPath="/team"
>
    <main class="team-main">
        <section class="team-hero shell">
            <span class="eyebrow">Team</span>
            <h1>The people behind FreeTheAi.</h1>
            <p class="team-lede">
                A small crew sharing free AI tools with everyone. Open source,
                community-run, and built in public on{" "}
                <a href={siteConfig.socials.github} target="_blank" rel="noreferrer">GitHub</a>{" "}
                and{" "}
                <a href="https://github.com/Free-The-Ai" target="_blank" rel="noreferrer">Free-The-Ai</a>.
            </p>
        </section>

        <section class="section shell team-grid-section">
            <div class="team-grid">
                {team.map((member) => (
                    <article class="team-card">
                        <div class="team-card-top">
                            <img
                                class="team-avatar"
                                src={member.avatar}
                                alt={`${member.name} GitHub avatar`}
                                loading="lazy"
                                width="96"
                                height="96"
                            />
                            <div class="team-card-meta">
                                <h2>{member.name}</h2>
                                <span class="team-role">{member.role}</span>
                            </div>
                        </div>
                        <p class="team-bio">{member.bio}</p>
                        <a
                            class="team-github"
                            href={member.github}
                            target="_blank"
                            rel="noreferrer"
                        >
                            <span class="material-symbols-outlined" aria-hidden="true">code</span>
                            <span>github.com/{member.githubHandle}</span>
                        </a>
                    </article>
                ))}
            </div>
        </section>

        <section class="section shell team-foot-section">
            <header class="section-head">
                <span class="eyebrow">Open source</span>
                <h2>Build with us.</h2>
            </header>
            <p class="team-foot-lede">
                FreeTheAi is open source. Issues, pull requests, and feature
                ideas are welcome on the public repo. The Discord is the fastest
                way to reach the team.
            </p>
            <div class="team-foot-links">
                <a class="primary-button" href={siteConfig.socials.github} target="_blank" rel="noreferrer">
                    <span>Star the repo</span>
                    <span class="cta-arrow" aria-hidden="true">&rarr;</span>
                </a>
                <a class="team-secondary" href={siteConfig.socials.discord} target="_blank" rel="noreferrer">
                    Join the Discord
                </a>
                <a class="team-secondary" href="/quickstart">
                    Try the quickstart
                </a>
            </div>
        </section>
    </main>
</Layout>

<style is:global>
    .team-main {
        gap: 28px;
        padding: 22px 0 64px;
    }

    .team-hero {
        display: grid;
        gap: 12px;
        padding: clamp(28px, 4.6vw, 52px);
    }

    .team-hero h1 {
        margin: 0;
        font-size: clamp(2.35rem, 4.7vw, 3.6rem);
        line-height: 1.04;
        letter-spacing: -0.045em;
    }

    .team-lede {
        margin: 0;
        max-width: 56ch;
        color: var(--muted);
        font-size: 1rem;
        line-height: 1.55;
    }

    .team-lede a {
        color: var(--accent-text);
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .team-grid-section {
        padding: clamp(22px, 3.8vw, 36px);
    }

    .team-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 16px;
    }

    .team-card {
        position: relative;
        display: grid;
        gap: 12px;
        padding: 22px;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius);
        background: var(--sk-inset-bg);
        box-shadow: var(--sk-inset-shadow);
        transition: border-color 200ms var(--ease-out-smooth), box-shadow 200ms var(--ease-out-smooth), transform 200ms var(--ease-out-smooth);
    }

    .team-card:hover {
        border-color: oklch(0.659 0.192 40.1 / 0.35);
        box-shadow: var(--sk-inset-shadow), 0 0 0 1px oklch(0.659 0.192 40.1 / 0.16);
        transform: translateY(-2px);
    }

    .team-card-top {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .team-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        border: 1px solid var(--sk-border);
        background: var(--bg);
        object-fit: cover;
        box-shadow: var(--sk-inset-shadow);
    }

    .team-card-meta h2 {
        margin: 0;
        font-family: var(--font-serif);
        font-size: 1.2rem;
        line-height: 1.15;
    }

    .team-role {
        display: inline-block;
        margin-top: 4px;
        padding: 2px 8px;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-full);
        background: var(--sk-shell-bg);
        color: var(--accent-text);
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .team-bio {
        margin: 0;
        color: var(--muted);
        font-size: 0.92rem;
        line-height: 1.55;
    }

    .team-github {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 12px;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-sm);
        background: var(--sk-shell-bg);
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 0.78rem;
        text-decoration: none;
        width: fit-content;
        transition: border-color 150ms var(--ease-out-smooth), color 150ms var(--ease-out-smooth);
    }

    .team-github:hover {
        border-color: oklch(0.659 0.192 40.1 / 0.42);
        color: var(--accent-text);
        text-shadow: var(--accent-text-glow);
    }

    .team-github .material-symbols-outlined {
        font-size: 16px;
    }

    .team-foot-section {
        display: grid;
        gap: 14px;
        padding: clamp(22px, 3.8vw, 36px);
    }

    .team-foot-section .section-head {
        display: grid;
        gap: 4px;
    }

    .team-foot-section h2 {
        margin: 0;
        font-family: var(--font-serif);
        font-size: 1.5rem;
        letter-spacing: -0.02em;
    }

    .team-foot-section .eyebrow {
        color: var(--dim);
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    .team-foot-lede {
        margin: 0;
        max-width: 60ch;
        color: var(--muted);
        font-size: 0.95rem;
        line-height: 1.55;
    }

    .team-foot-links {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 14px;
    }

    .team-foot-links .cta-arrow {
        opacity: 0.65;
        font-size: 0.9rem;
    }

    .team-secondary {
        color: var(--muted);
        font-size: 0.92rem;
        text-decoration: none;
        border-bottom: 1px solid var(--sk-border);
        padding-bottom: 2px;
    }

    .team-secondary:hover {
        color: var(--accent-text);
        border-color: oklch(0.659 0.192 40.1 / 0.42);
    }

    @media (max-width: 560px) {
        .team-card {
            padding: 18px;
        }
    }
</style>
