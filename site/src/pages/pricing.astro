---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config/site";
import {
    buildBreadcrumbJsonLd,
    buildOrganizationJsonLd,
    buildPaidPlanJsonLd,
    buildSoftwareJsonLd,
    buildWebsiteJsonLd,
    buildWebApiJsonLd,
} from "../utils/jsonLd";
import paidPlan from "../data/paid-plan.json";

const jsonLd = [
    buildWebsiteJsonLd(),
    buildOrganizationJsonLd(),
    buildSoftwareJsonLd(),
    buildWebApiJsonLd(),
    buildPaidPlanJsonLd(paidPlan.plan),
    buildBreadcrumbJsonLd([
        { name: "FreeTheAi", url: "https://freetheai.xyz/home" },
        { name: "Pricing", url: "https://freetheai.xyz/pricing" },
    ]),
];

const paidModelCount = paidPlan.model_groups.reduce(
    (total, group) => total + group.models.length,
    0,
);
---

<Layout
    title="FreeTheAi Paid API Pricing - $8 Higher-Power Model Slots"
    description="FreeTheAi paid API pricing: $8/month launch slots, 24 paid aliases, request-unit costs, hourly and daily limits, and a separate higher-power model catalog."
    jsonLd={jsonLd}
    currentPath="/pricing"
>
    <main class="pricing-main">
        <section class="pricing-hero shell">
            <div class="pricing-hero-copy">
                <span class="eyebrow">Paid API</span>
                <h1>More powerful models when the free API is not enough.</h1>
                <p class="hero-text">
                    The free API stays free. The paid plan is a separate, limited-seat
                    option for builders who need stronger models, steadier access, and
                    higher-powered routes without crowding the free pools.
                </p>
                <div class="hero-actions">
                    <a class="primary-button" href={siteConfig.socials.discord} target="_blank" rel="noreferrer">
                        Claim a paid slot
                        <span>&rarr;</span>
                    </a>
                    <a class="ghost-button" href="/models">Browse free models</a>
                </div>
                <p class="pricing-note">
                    Launch slots are limited while we measure real usage and keep the
                    paid account pools healthy.
                </p>
                <p class="pricing-endpoint docs-code-group">
                    Paid base URL: <code>{paidPlan.base_url}</code>
                    <button class="copy-btn pricing-copy-button" type="button" title="Copy paid base URL">
                        <span class="material-symbols-outlined">content_copy</span>
                    </button>
                </p>
            </div>

            <article class="pricing-card pricing-plan-card">
                <div class="pricing-plan-head">
                    <div>
                        <span class="eyebrow">{paidPlan.plan.name}</span>
                        <h2>{paidModelCount} paid aliases</h2>
                    </div>
                    <span>limited seats</span>
                </div>
                <div class="pricing-price">
                    <strong>{paidPlan.plan.price}</strong>
                    <span>/ {paidPlan.plan.period}</span>
                </div>
                <p>
                    {paidPlan.plan.summary}
                </p>
                <div class="pricing-plan-grid">
                    {paidPlan.plan.limits.map(({ value, label }) => (
                        <div>
                            <strong>{value}</strong>
                            <span>{label}</span>
                        </div>
                    ))}
                </div>
            </article>
        </section>

        <section class="section shell pricing-section">
            <div class="section-head">
                <span class="eyebrow">How limits work</span>
                <h2>Affordable, but protected from pool drain.</h2>
                <p>
                    The paid plan is designed to hook real builders without letting one
                    user burn through the launch inventory. Each request deducts the
                    listed model cost from your hourly, daily, and monthly budget.
                </p>
            </div>

            <div class="pricing-feature-grid">
                <article class="capability-card">
                    <span class="capability-icon material-symbols-outlined">bolt</span>
                    <h3>Different catalog from free</h3>
                    <p>
                        Paid models live on separate <code>sky/*</code> and
                        <code>pbl/*</code> aliases. They are meant for harder coding,
                        reasoning, and long-form work.
                    </p>
                </article>
                <article class="capability-card">
                    <span class="capability-icon material-symbols-outlined">speed</span>
                    <h3>Request-unit pricing</h3>
                    <p>
                        Cheap hook models can cost <code>0.5</code> units, normal
                        models cost <code>1</code>, and heavy models cost up to
                        <code>4</code> units per request.
                    </p>
                </article>
                <article class="capability-card">
                    <span class="capability-icon material-symbols-outlined">lock</span>
                    <h3>Launch safety limits</h3>
                    <p>
                        Accounts have hourly, daily, monthly, and concurrency limits.
                        The <code>pbl/*</code> pool also has a separate
                        <code>250</code> unit daily cap to keep premium routes
                        available.
                    </p>
                </article>
            </div>
        </section>

        <section class="section shell pricing-section">
            <div class="section-head">
                <span class="eyebrow">Paid model costs</span>
                <h2>{paidModelCount} priced launch aliases.</h2>
                <p>
                    These aliases are rendered from <code>/paid-plan.json</code>.
                    Copy a model name directly from the table and use the listed unit
                    cost to estimate hourly and daily capacity.
                </p>
            </div>

            <div class="pricing-model-grid">
                {paidPlan.model_groups.map((group) => (
                    <article class="pricing-card">
                        <div class="pricing-model-head">
                            <h3>{group.label}</h3>
                            <span>{group.description}</span>
                        </div>
                        <div class="pricing-model-table" role="table" aria-label={`${group.label} unit costs`}>
                            <div class="pricing-model-row pricing-model-row-head" role="row">
                                <span>Model</span>
                                <span>Route</span>
                                <span>Cost</span>
                                <span>Copy</span>
                            </div>
                            {group.models.map((model) => (
                                <div class="pricing-model-row" role="row">
                                    <span class="pricing-model-name docs-code-group">
                                        <code>{model.id}</code>
                                    </span>
                                    <span class="pricing-route-pill">{model.route}</span>
                                    <strong>{model.unit_label}</strong>
                                    <button class="copy-btn pricing-model-copy pricing-model-copy-mobile" type="button" title={`Copy ${model.id}`}>
                                        <code class="sr-only">{model.id}</code>
                                        <span class="material-symbols-outlined">content_copy</span>
                                    </button>
                                </div>
                            ))}
                        </div>
                    </article>
                ))}
            </div>
        </section>

        <section class="section shell pricing-section">
            <article class="cta-banner pricing-cta">
                <div>
                    <span class="eyebrow">Limited launch</span>
                    <h2>Want a slot?</h2>
                    <p>
                        Join Discord and ask for the paid plan. The owner will issue a
                        monthly paid API key while launch slots are available.
                    </p>
                </div>
                <div class="cta-actions">
                    <a class="primary-button" href={siteConfig.socials.discord} target="_blank" rel="noreferrer">
                        Join Discord
                        <span>&rarr;</span>
                    </a>
                    <a class="ghost-button" href="/docs">Read API docs</a>
                </div>
            </article>
        </section>
    </main>
</Layout>

<style>
    .pricing-main {
        gap: 32px;
        padding: 22px 0 72px;
    }

    .pricing-hero {
        display: grid;
        grid-template-columns: minmax(0, 0.92fr) minmax(360px, 0.62fr);
        gap: clamp(24px, 4vw, 44px);
        align-items: center;
        min-height: auto;
        padding: clamp(26px, 4.4vw, 48px);
    }

    .pricing-hero-copy {
        display: grid;
        gap: 16px;
        min-width: 0;
    }

    .pricing-hero h1 {
        max-width: 13.5ch;
        font-size: clamp(2.45rem, 5.8vw, 4.85rem);
        line-height: 0.98;
        letter-spacing: -0.055em;
    }

    .pricing-note {
        max-width: 58ch;
        margin: 0;
        color: var(--dim);
        font-size: 0.9rem;
        line-height: 1.55;
    }

    .pricing-endpoint {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        width: fit-content;
        max-width: 100%;
        margin: 2px 0 0;
        padding: 10px 12px;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-sm);
        background: var(--sk-inset-bg);
        box-shadow: var(--sk-inset-shadow);
        color: var(--muted);
        font-size: 0.85rem;
    }

    .pricing-endpoint code {
        color: var(--text);
        font-family: var(--font-mono);
    }

    .pricing-card {
        min-width: 0;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius);
        background: var(--sk-shell-bg);
        box-shadow: var(--sk-raised-shadow);
        padding: clamp(20px, 2.7vw, 28px);
    }

    .pricing-card p {
        margin: 0;
        color: var(--muted);
        line-height: 1.65;
    }

    .pricing-plan-card {
        position: relative;
        overflow: hidden;
        display: grid;
        gap: 20px;
    }

    .pricing-plan-card::before {
        content: "";
        position: absolute;
        inset: -40% -20% auto auto;
        width: 260px;
        height: 260px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(238, 93, 32, 0.22), transparent 64%);
        pointer-events: none;
    }

    .pricing-plan-head {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: start;
        justify-content: space-between;
        gap: 18px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--sk-border);
    }

    .pricing-plan-head h2 {
        margin: 6px 0 0;
        color: var(--text);
        font-size: clamp(1.45rem, 3vw, 2.05rem);
        letter-spacing: -0.035em;
    }

    .pricing-plan-head > span {
        color: var(--accent-text);
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-shadow: var(--accent-text-glow);
        white-space: nowrap;
    }

    .pricing-price {
        display: flex;
        align-items: end;
        gap: 10px;
    }

    .pricing-price strong {
        color: var(--accent-text-strong);
        font-family: var(--font-serif);
        font-size: clamp(3.6rem, 8vw, 5.4rem);
        font-weight: 500;
        line-height: 0.88;
        letter-spacing: -0.08em;
        text-shadow: var(--accent-text-glow);
    }

    .pricing-price span {
        margin-bottom: 8px;
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .pricing-plan-grid,
    .pricing-feature-grid,
    .pricing-model-grid {
        display: grid;
        gap: 16px;
    }

    .pricing-plan-grid {
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    }

    .pricing-plan-grid div {
        display: grid;
        gap: 4px;
        min-width: 0;
        padding: 14px;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-sm);
        background: var(--sk-inset-bg);
        box-shadow: var(--sk-inset-shadow);
    }

    .pricing-plan-grid strong {
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 1.05rem;
    }

    .pricing-plan-grid span {
        color: var(--muted);
        font-size: 0.78rem;
        line-height: 1.35;
    }

    .pricing-feature-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .pricing-section {
        gap: clamp(22px, 3vw, 30px);
        padding: clamp(24px, 4vw, 38px);
    }

    .pricing-model-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        align-items: start;
    }

    .pricing-model-head {
        display: flex;
        align-items: start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 18px;
    }

    .pricing-model-head span {
        color: var(--dim);
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .pricing-model-table {
        display: grid;
        gap: 6px;
    }

    .pricing-model-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 76px 108px 42px;
        gap: 12px;
        align-items: center;
        min-width: 0;
        padding: 10px 12px;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-sm);
        background: var(--sk-inset-bg);
        box-shadow: var(--sk-inset-shadow);
    }

    .pricing-model-row-head {
        padding: 2px 12px 6px;
        border: 0;
        background: transparent;
        box-shadow: none;
        color: var(--dim);
        font-family: var(--font-mono);
        font-size: 0.68rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .pricing-model-name {
        min-width: 0;
    }

    .pricing-model-row code {
        min-width: 0;
        overflow: hidden;
        color: var(--text);
        font-family: var(--font-mono);
        font-size: 0.78rem;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .pricing-route-pill {
        width: fit-content;
        max-width: 100%;
        padding: 4px 7px;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-sm);
        background: rgba(255, 255, 255, 0.035);
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 0.7rem;
        text-transform: uppercase;
    }

    .pricing-model-row strong {
        color: var(--accent-text);
        font-family: var(--font-mono);
        font-size: 0.74rem;
        font-weight: 700;
        text-shadow: var(--accent-text-glow);
        white-space: nowrap;
    }

    .pricing-copy-button,
    .pricing-model-copy {
        flex: 0 0 auto;
        width: 30px;
        height: 30px;
        min-height: 30px;
        padding: 0;
        border: 1px solid var(--sk-border);
        border-radius: var(--radius-sm);
        background: var(--sk-inset-bg);
        color: var(--muted);
        box-shadow: var(--sk-inset-shadow);
        cursor: pointer;
    }

    .pricing-copy-button:hover,
    .pricing-model-copy:hover {
        color: var(--text);
        border-color: rgba(238, 93, 32, 0.42);
    }

    .pricing-cta {
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
    }

    @media (max-width: 1120px) {
        .pricing-hero,
        .pricing-model-grid,
        .pricing-cta {
            grid-template-columns: 1fr;
        }

        .pricing-hero h1 {
            max-width: 15ch;
        }

        .pricing-feature-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 560px) {
        .pricing-main {
            gap: 24px;
            padding-top: 10px;
        }

        .pricing-hero {
            gap: 22px;
            padding: 18px;
        }

        .pricing-hero h1 {
            font-size: clamp(2.25rem, 13vw, 3.2rem);
            line-height: 1.02;
        }

        .pricing-card {
            padding: 16px;
        }

        .pricing-section {
            padding: 18px;
        }

        .pricing-plan-grid {
            grid-template-columns: 1fr;
        }

        .pricing-model-head {
            flex-direction: column;
            gap: 6px;
        }

        .pricing-plan-head {
            flex-direction: column;
            gap: 8px;
        }

        .pricing-model-row {
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 8px;
        }

        .pricing-model-row-head {
            display: none;
        }

        .pricing-route-pill {
            grid-column: 1;
        }

        .pricing-model-row strong {
            grid-column: 1;
        }

        .pricing-model-copy-mobile {
            grid-row: 1 / span 3;
            grid-column: 2;
        }
    }
</style>
